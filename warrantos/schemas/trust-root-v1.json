{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://warrantos.dev/schema/trust-root-v1.json",
  "title": "WarrantOS pinned signer trust root",
  "type": "object",
  "required": ["schema", "key_id", "algorithm", "public_key"],
  "properties": {
    "schema": {"const": "warrantos-trust-root/v1"},
    "key_id": {"type": "string", "minLength": 1},
    "algorithm": {"const": "ed25519"},
    "public_key": {"type": "string", "minLength": 43, "maxLength": 44},
    "fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$"}
  },
  "additionalProperties": false
}
